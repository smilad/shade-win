<UserControl x:Class="Shade.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel>

            <!-- ── Hero card: status orb + label + power button + listener ─────── -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                <StackPanel>
                    <DockPanel>
                        <!-- Status orb -->
                        <Grid Width="44" Height="44" VerticalAlignment="Center" Margin="0,0,14,0">
                            <Ellipse x:Name="OrbHalo" Fill="#3322D3EE" />
                            <Ellipse x:Name="OrbCore" Width="20" Height="20" Fill="#FF22D3EE"
                                     HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>

                        <!-- Power button (right) -->
                        <Button x:Name="PowerBtn" DockPanel.Dock="Right" Width="120" Height="40"
                                Click="PowerBtn_Click" Cursor="Hand"
                                Background="{StaticResource StartButtonBrush}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" CornerRadius="10"
                                            Background="{TemplateBinding Background}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="0.9" />
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Opacity" Value="0.4" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock x:Name="PowerIcon" Text="▶" Foreground="White"
                                           FontSize="11" FontWeight="Bold"
                                           VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBlock x:Name="PowerLabel" Text="START" Foreground="White"
                                           FontSize="13" FontWeight="Bold" />
                            </StackPanel>
                        </Button>

                        <!-- Title + subtitle -->
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="HeroTitle" Text="Ready to connect"
                                       FontSize="20" FontWeight="SemiBold" />
                            <TextBlock x:Name="HeroSubtitle" Text="Add and select a profile to get started."
                                       Style="{StaticResource SmallText}" Margin="0,2,0,0"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </DockPanel>

                    <Rectangle Height="1" Fill="{StaticResource GlassStroke}" Margin="0,14" />

                    <!-- Listener row -->
                    <DockPanel>
                        <Border Background="#1422D3EE" CornerRadius="999" Padding="6,2"
                                DockPanel.Dock="Right" VerticalAlignment="Center">
                            <TextBlock Text="HTTP · SOCKS5" FontSize="9" FontWeight="SemiBold"
                                       Foreground="{StaticResource Secondary}" />
                        </Border>
                        <TextBlock Text="↘" Foreground="{StaticResource AccentCyan}" FontSize="14"
                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock x:Name="ListenerLine" Style="{StaticResource MonoText}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   Text="HTTP 127.0.0.1:1080  ·  SOCKS5 127.0.0.1:8080" />
                    </DockPanel>
                </StackPanel>
            </Border>

            <!-- ── Speed meter (visible only while running) ─────────────────────── -->
            <Border x:Name="SpeedCard" Style="{StaticResource Card}" Margin="0,0,0,14"
                    Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="LIVE TRAFFIC" FontSize="10" FontWeight="SemiBold"
                               Foreground="{StaticResource Tertiary}" Margin="0,0,0,10" />

                    <!-- Speed bars -->
                    <DockPanel Margin="0,0,0,6">
                        <TextBlock Text="↓" Foreground="{StaticResource AccentCyan}"
                                   FontWeight="Bold" Width="14" />
                        <TextBlock x:Name="SpeedDownText" Text="0 KB/s" Style="{StaticResource MonoText}"
                                   DockPanel.Dock="Right" Width="80" TextAlignment="Right"
                                   Foreground="{StaticResource AccentCyan}" />
                        <Border Height="6" Margin="6,0" CornerRadius="3" Background="#10FFFFFF"
                                ClipToBounds="True">
                            <Rectangle x:Name="SpeedDownBar" Fill="{StaticResource DownBarBrush}"
                                       HorizontalAlignment="Left" Width="0" />
                        </Border>
                    </DockPanel>
                    <DockPanel Margin="0,0,0,12">
                        <TextBlock Text="↑" Foreground="{StaticResource AccentPurple}"
                                   FontWeight="Bold" Width="14" />
                        <TextBlock x:Name="SpeedUpText" Text="0 KB/s" Style="{StaticResource MonoText}"
                                   DockPanel.Dock="Right" Width="80" TextAlignment="Right"
                                   Foreground="{StaticResource AccentPurple}" />
                        <Border Height="6" Margin="6,0" CornerRadius="3" Background="#10FFFFFF"
                                ClipToBounds="True">
                            <Rectangle x:Name="SpeedUpBar" Fill="{StaticResource UpBarBrush}"
                                       HorizontalAlignment="Left" Width="0" />
                        </Border>
                    </DockPanel>

                    <!-- Totals row -->
                    <Border Background="#08FFFFFF" BorderBrush="{StaticResource GlassStroke}"
                            BorderThickness="1" CornerRadius="8" Padding="0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition Width="1" />
                                <ColumnDefinition />
                                <ColumnDefinition Width="1" />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,8" HorizontalAlignment="Center">
                                <TextBlock x:Name="TotalDownText" Text="0 B"
                                           FontFamily="Consolas" FontWeight="Bold"
                                           Foreground="{StaticResource AccentCyan}"
                                           FontSize="13" HorizontalAlignment="Center" />
                                <TextBlock Text="↓ Total" Style="{StaticResource SmallText}"
                                           FontSize="9" HorizontalAlignment="Center" />
                            </StackPanel>
                            <Rectangle Grid.Column="1" Fill="{StaticResource GlassStroke}" Width="1" />
                            <StackPanel Grid.Column="2" Margin="0,8" HorizontalAlignment="Center">
                                <TextBlock x:Name="TotalUpText" Text="0 B"
                                           FontFamily="Consolas" FontWeight="Bold"
                                           Foreground="{StaticResource AccentPurple}"
                                           FontSize="13" HorizontalAlignment="Center" />
                                <TextBlock Text="↑ Total" Style="{StaticResource SmallText}"
                                           FontSize="9" HorizontalAlignment="Center" />
                            </StackPanel>
                            <Rectangle Grid.Column="3" Fill="{StaticResource GlassStroke}" Width="1" />
                            <StackPanel Grid.Column="4" Margin="0,8" HorizontalAlignment="Center">
                                <TextBlock x:Name="TotalSessionText" Text="0 B"
                                           FontFamily="Consolas" FontWeight="Bold"
                                           Foreground="{StaticResource AccentCyan}"
                                           FontSize="13" HorizontalAlignment="Center" />
                                <TextBlock Text="Session" Style="{StaticResource SmallText}"
                                           FontSize="9" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ── Profile (Credentials) card ───────────────────────────────────── -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                <StackPanel>
                    <DockPanel Margin="0,0,0,10">
                        <TextBlock Text="🔑 Profile" Foreground="{StaticResource AccentPurple}"
                                   FontSize="11" FontWeight="Bold" Width="80" />

                        <Button x:Name="AddProfileBtn" DockPanel.Dock="Right"
                                Style="{StaticResource LinkButton}" Click="AddProfileBtn_Click"
                                FontSize="14" Margin="6,0,0,0">
                            <TextBlock Text="＋" Foreground="{StaticResource AccentPurple}" FontSize="16" />
                        </Button>

                        <!-- LB toggle -->
                        <Border DockPanel.Dock="Right" Padding="6,2" CornerRadius="999"
                                Background="#0DFFFFFF" Margin="6,0,0,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="LB" FontSize="9" FontWeight="Bold"
                                           Margin="0,0,6,0" VerticalAlignment="Center"
                                           Foreground="{StaticResource Secondary}" />
                                <CheckBox x:Name="LbToggle" Style="{StaticResource ToggleSwitch}"
                                          Click="LbToggle_Click" />
                            </StackPanel>
                        </Border>

                        <!-- LB strategy combo (when LB on) -->
                        <ComboBox x:Name="LbStrategyCombo" DockPanel.Dock="Right" Width="160"
                                  Margin="0,0,8,0" SelectionChanged="LbStrategyCombo_Changed"
                                  Visibility="Collapsed" />

                        <!-- Empty filler -->
                        <Border />
                    </DockPanel>

                    <!-- Active profile selector button (or empty state) -->
                    <Grid x:Name="ProfileBody">
                        <!-- Empty state -->
                        <StackPanel x:Name="EmptyProfileBlock" Visibility="Collapsed"
                                    HorizontalAlignment="Center" Margin="0,8">
                            <TextBlock Text="No profiles yet" Style="{StaticResource MutedText}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="Add your Script ID and Auth Key as a named profile."
                                       Style="{StaticResource SmallText}"
                                       HorizontalAlignment="Center" Margin="0,4" />
                            <Button Style="{StaticResource PrimaryButton}" Margin="0,8,0,0"
                                    Padding="12,6" Click="AddProfileBtn_Click"
                                    HorizontalAlignment="Center">
                                <TextBlock Text="＋  Add First Profile" />
                            </Button>
                        </StackPanel>

                        <!-- Active profile button -->
                        <Button x:Name="ActiveProfileBtn" Style="{StaticResource GhostButton}"
                                Click="OpenProfilePicker_Click" Padding="12,10"
                                HorizontalContentAlignment="Stretch"
                                Visibility="Collapsed">
                            <DockPanel>
                                <TextBlock Text="⌄" DockPanel.Dock="Right"
                                           Foreground="{StaticResource Secondary}"
                                           FontSize="12" VerticalAlignment="Center" />
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="ActiveProfileName" Text="Default"
                                                   FontWeight="SemiBold" />
                                        <Border x:Name="CFBadge" Background="#26FB923C"
                                                CornerRadius="999" Padding="6,1" Margin="6,0,0,0"
                                                Visibility="Collapsed">
                                            <TextBlock Text="CF" FontSize="9" FontWeight="Bold"
                                                       Foreground="{StaticResource AccentOrange}" />
                                        </Border>
                                    </StackPanel>
                                    <TextBlock x:Name="ActiveProfileSID" Style="{StaticResource MonoText}"
                                               FontSize="10" Margin="0,3,0,0"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </DockPanel>
                        </Button>
                    </Grid>

                    <!-- Edit link -->
                    <DockPanel x:Name="EditLinkRow" Margin="0,8,0,0" Visibility="Collapsed">
                        <Button DockPanel.Dock="Right" Style="{StaticResource LinkButton}"
                                Click="EditProfileBtn_Click">
                            <TextBlock Text="✎  Edit profile" Foreground="{StaticResource Secondary}" FontSize="10" />
                        </Button>
                        <Border />
                    </DockPanel>
                </StackPanel>
            </Border>

            <!-- ── Connectivity test card (visible only while running) ──────────── -->
            <Border x:Name="TestCard" Style="{StaticResource Card}" Margin="0,0,0,14"
                    Visibility="Collapsed">
                <DockPanel>
                    <Button DockPanel.Dock="Right" Style="{StaticResource GhostButton}" Width="110"
                            x:Name="TestBtn" Click="TestBtn_Click" Padding="12,8">
                        <TextBlock x:Name="TestBtnText" Text="Run test" />
                    </Button>
                    <StackPanel Margin="0,0,12,0">
                        <DockPanel>
                            <TextBlock Text="📊" Margin="0,0,8,0" FontSize="16" VerticalAlignment="Center" />
                            <TextBlock Text="YouTube reachability" FontSize="13" FontWeight="SemiBold" />
                        </DockPanel>
                        <TextBlock x:Name="TestResultText" Style="{StaticResource SmallText}" Margin="24,4,0,0" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- ── Google IP Scanner card ────────────────────────────────────────── -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                <StackPanel>
                    <DockPanel>
                        <Button x:Name="ScanBtn" DockPanel.Dock="Right" Style="{StaticResource GhostButton}"
                                Click="ScanBtn_Click" Width="120">
                            <TextBlock x:Name="ScanBtnText" Text="Run scan" />
                        </Button>
                        <StackPanel>
                            <DockPanel>
                                <TextBlock Text="🌐" Margin="0,0,8,0" FontSize="16" VerticalAlignment="Center" />
                                <TextBlock Text="Google IP Scanner" FontSize="13" FontWeight="SemiBold" />
                            </DockPanel>
                            <TextBlock Text="Find the fastest reachable Google edge IP for your network."
                                       Style="{StaticResource SmallText}" Margin="24,4,0,0" />
                        </StackPanel>
                    </DockPanel>

                    <Border x:Name="ScanLogBox" Margin="0,12,0,0" Background="#22000000"
                            BorderBrush="{StaticResource GlassStroke}" BorderThickness="1"
                            CornerRadius="8" Padding="10" Visibility="Collapsed" Height="120">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" x:Name="ScanScroll">
                            <ItemsControl x:Name="ScanList" />
                        </ScrollViewer>
                    </Border>

                    <DockPanel x:Name="ScanResultRow" Margin="0,12,0,0" Visibility="Collapsed">
                        <Button DockPanel.Dock="Right" Style="{StaticResource PrimaryButton}"
                                x:Name="ApplyScanBtn" Click="ApplyScanBtn_Click" Padding="12,6">
                            <TextBlock x:Name="ApplyScanText" Text="Apply 1.2.3.4" Foreground="#FF111122" />
                        </Button>
                        <TextBlock x:Name="ScanResultText" Style="{StaticResource MonoText}"
                                   VerticalAlignment="Center" />
                    </DockPanel>
                </StackPanel>
            </Border>

            <!-- ── System Proxy card ─────────────────────────────────────────────── -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                <DockPanel>
                    <CheckBox x:Name="SystemProxyToggle" Style="{StaticResource ToggleSwitch}"
                              DockPanel.Dock="Right" Click="SystemProxyToggle_Click" />
                    <StackPanel>
                        <DockPanel>
                            <TextBlock Text="🛡" Margin="0,0,8,0" FontSize="16" VerticalAlignment="Center" />
                            <TextBlock Text="Set as system proxy" FontSize="13" FontWeight="SemiBold" />
                        </DockPanel>
                        <TextBlock Style="{StaticResource SmallText}" Margin="24,4,0,0"
                                   TextWrapping="Wrap"
                                   Text="Routes HTTP/HTTPS apps through Shade. Edge, Chrome, .NET apps respect this; Firefox uses its own proxy config." />
                    </StackPanel>
                </DockPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
