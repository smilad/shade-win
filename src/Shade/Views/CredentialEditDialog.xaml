<Window x:Class="Shade.Views.CredentialEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Profile" Width="380" Height="460"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow" ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{StaticResource WindowBackground}"
        Foreground="{StaticResource Primary}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="1" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <DockPanel Grid.Row="0" Margin="0,0,0,12">
            <Button DockPanel.Dock="Left" Style="{StaticResource LinkButton}" Click="Cancel_Click">
                <TextBlock Text="Cancel" Foreground="{StaticResource Secondary}" FontSize="13" />
            </Button>
            <Button DockPanel.Dock="Right" Style="{StaticResource LinkButton}" Click="Save_Click" x:Name="SaveBtn">
                <TextBlock Text="Save" Foreground="{StaticResource AccentPurple}" FontWeight="SemiBold" FontSize="13" />
            </Button>
            <TextBlock x:Name="TitleText" Text="New Profile" FontSize="14" FontWeight="SemiBold"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
        </DockPanel>
        <Rectangle Grid.Row="1" Fill="{StaticResource GlassStroke}" Height="1" Margin="0,0,0,16" />

        <StackPanel Grid.Row="2">
            <TextBlock Text="PROFILE NAME" FontSize="10" FontWeight="Bold"
                       Foreground="{StaticResource Tertiary}" Margin="0,0,0,4" />
            <TextBlock Text="e.g. Home, School, Work" Style="{StaticResource SmallText}" Margin="0,0,0,4" />
            <TextBox x:Name="NameBox" Text="" Margin="0,0,0,12" />

            <TextBlock Text="SCRIPT ID" FontSize="10" FontWeight="Bold"
                       Foreground="{StaticResource Tertiary}" Margin="0,0,0,4" />
            <TextBlock Text="Deployment ID from your Google Apps Script web app"
                       Style="{StaticResource SmallText}" Margin="0,0,0,4" />
            <TextBox x:Name="ScriptIDBox" Margin="0,0,0,12" />

            <TextBlock Text="AUTH KEY" FontSize="10" FontWeight="Bold"
                       Foreground="{StaticResource Tertiary}" Margin="0,0,0,4" />
            <TextBlock Text="The same AUTH_KEY you set in Code.gs"
                       Style="{StaticResource SmallText}" Margin="0,0,0,4" />
            <Grid Margin="0,0,0,12">
                <PasswordBox x:Name="AuthKeyBox" />
                <TextBox x:Name="AuthKeyVisible" Visibility="Collapsed" />
                <Button Width="32" HorizontalAlignment="Right" Style="{StaticResource LinkButton}"
                        Click="ToggleVisibility_Click">
                    <TextBlock x:Name="EyeIcon" Text="👁" Foreground="{StaticResource Secondary}" FontSize="13" />
                </Button>
            </Grid>

            <Border Background="#26FB923C" CornerRadius="8" Padding="10" Margin="0,8,0,0">
                <DockPanel>
                    <CheckBox x:Name="CFCheck" Style="{StaticResource ToggleSwitch}"
                              DockPanel.Dock="Right" />
                    <StackPanel>
                        <TextBlock Text="Cloudflare profile" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentOrange}" />
                        <TextBlock Text="Mark this if the script ID points at a Cloudflare relay (used by LB strategy filters)."
                                   Style="{StaticResource SmallText}" TextWrapping="Wrap" Margin="0,4,0,0" />
                    </StackPanel>
                </DockPanel>
            </Border>
        </StackPanel>
    </Grid>
</Window>
