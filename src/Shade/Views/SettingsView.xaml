<UserControl x:Class="Shade.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>

            <!-- Header -->
            <StackPanel Margin="0,0,0,18">
                <TextBlock Text="Settings" Style="{StaticResource Heading}" />
                <TextBlock Text="Everything here has sensible defaults. Only touch it if you know why."
                           Style="{StaticResource MutedText}" Margin="0,4,0,0" />
            </StackPanel>

            <!-- Network section -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="🌐 Network" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource Tertiary}" Margin="0,0,0,12" />

                    <TextBlock Text="LISTEN HOST" FontSize="10" FontWeight="Bold"
                               Foreground="{StaticResource Tertiary}" />
                    <TextBlock Text="Bind address for HTTP + SOCKS5"
                               Style="{StaticResource SmallText}" />
                    <TextBox x:Name="ListenHostBox" Text="127.0.0.1" Margin="0,4,0,12" />

                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left" Width="180">
                            <TextBlock Text="HTTP PORT" FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource Tertiary}" />
                            <TextBox x:Name="HttpPortBox" Text="1080" Margin="0,4,8,0" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="SOCKS5 PORT" FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource Tertiary}" />
                            <TextBox x:Name="SocksPortBox" Text="8080" Margin="0,4,0,0" />
                        </StackPanel>
                    </DockPanel>
                </StackPanel>
            </Border>

            <!-- Fronting section -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="🌿 Fronting" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource Tertiary}" Margin="0,0,0,12" />
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left" Width="220">
                            <TextBlock Text="FRONT DOMAIN" FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource Tertiary}" />
                            <TextBlock Text="SNI shown to network" Style="{StaticResource SmallText}" />
                            <TextBox x:Name="FrontDomainBox" Text="www.google.com" Margin="0,4,8,0" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="GOOGLE IP" FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource Tertiary}" />
                            <TextBlock Text="Edge IP for relay" Style="{StaticResource SmallText}" />
                            <TextBox x:Name="GoogleIPBox" Text="216.239.38.120" Margin="0,4,0,0" />
                        </StackPanel>
                    </DockPanel>
                </StackPanel>
            </Border>

            <!-- Advanced -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="🎛 Advanced" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource Tertiary}" Margin="0,0,0,12" />

                    <DockPanel Margin="0,0,0,8">
                        <TextBlock Text="Log Level" FontSize="11" Foreground="{StaticResource Secondary}" VerticalAlignment="Center" />
                        <ComboBox x:Name="LogLevelCombo" Width="90" DockPanel.Dock="Right" />
                    </DockPanel>
                    <Rectangle Height="1" Fill="{StaticResource GlassStroke}" Opacity="0.4" Margin="0,4" />
                    <DockPanel>
                        <TextBlock Text="Verify SSL" FontSize="11" Foreground="{StaticResource Secondary}" VerticalAlignment="Center" />
                        <CheckBox x:Name="VerifySSLToggle" Style="{StaticResource ToggleSwitch}" DockPanel.Dock="Right" />
                    </DockPanel>
                </StackPanel>
            </Border>

            <!-- TLS / Certificate -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="🔒 TLS / Certificate" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource Tertiary}" Margin="0,0,0,8" />
                    <TextBlock TextWrapping="Wrap" Style="{StaticResource SmallText}"
                               Text="If sites fail with SSL errors, use this to refresh the MITM certificate." />
                    <DockPanel Margin="0,12,0,0">
                        <Button DockPanel.Dock="Left" Style="{StaticResource PrimaryButton}"
                                x:Name="RepairBtn" Click="RepairBtn_Click" Padding="12,6">
                            <TextBlock Text="🔧  Repair Certificate" Foreground="#FF111122" FontWeight="SemiBold" />
                        </Button>
                        <TextBlock x:Name="RepairStatusText" Style="{StaticResource SmallText}"
                                   VerticalAlignment="Center" Margin="12,0,0,0" />
                    </DockPanel>
                </StackPanel>
            </Border>

            <!-- Footer with Save / Revert -->
            <DockPanel Margin="0,4,0,12">
                <TextBlock x:Name="SavedBadge" Text="✓ Saved" Foreground="{StaticResource AccentGreen}"
                           FontSize="12" Visibility="Collapsed" VerticalAlignment="Center" />
                <Button DockPanel.Dock="Right" Style="{StaticResource PrimaryButton}" x:Name="SaveBtn"
                        Click="SaveBtn_Click" Padding="14,6" Margin="6,0,0,0">
                    <TextBlock Text="Save" Foreground="#FF111122" FontWeight="SemiBold" />
                </Button>
                <Button DockPanel.Dock="Right" Style="{StaticResource GhostButton}" Click="RevertBtn_Click"
                        Padding="14,6">
                    <TextBlock Text="Revert" />
                </Button>
            </DockPanel>

            <Border x:Name="RestartHint" Visibility="Collapsed" Background="#33EAB308"
                    BorderBrush="#80EAB308" BorderThickness="1" CornerRadius="8" Padding="12,8">
                <DockPanel>
                    <TextBlock Text="⚠" Foreground="{StaticResource AccentYellow}" FontSize="14" Margin="0,0,8,0" />
                    <TextBlock Text="Changes take effect after Stop → Start." Foreground="{StaticResource AccentYellow}" />
                </DockPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
