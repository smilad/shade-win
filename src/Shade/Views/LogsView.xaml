<UserControl x:Class="Shade.Views.LogsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel>
        <DockPanel Margin="0,0,0,12" DockPanel.Dock="Top">
            <TextBlock Text="Logs" Style="{StaticResource Heading}" />
            <Button DockPanel.Dock="Right" Style="{StaticResource GhostButton}" Click="Clear_Click" Padding="14,6">
                <TextBlock Text="Clear" />
            </Button>
        </DockPanel>
        <TextBlock DockPanel.Dock="Top" Style="{StaticResource MutedText}"
                   Text="Core + system messages. Open this tab if something fails."
                   Margin="0,0,0,12" />

        <Border Background="#59000000" BorderBrush="{StaticResource GlassStroke}"
                BorderThickness="1" CornerRadius="10">
            <ScrollViewer x:Name="LogScroll" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto">
                <TextBox x:Name="LogText" IsReadOnly="True"
                         Background="Transparent" BorderThickness="0"
                         FontFamily="Consolas, Cascadia Mono"
                         FontSize="11"
                         Foreground="{StaticResource Primary}"
                         TextWrapping="NoWrap" Padding="12" />
            </ScrollViewer>
        </Border>
    </DockPanel>
</UserControl>
