<Window x:Class="Shade.Views.CredentialPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Profiles" Width="360" Height="460"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow" ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{StaticResource WindowBackground}"
        Foreground="{StaticResource Primary}">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="1" />
            <RowDefinition Height="*" />
            <RowDefinition Height="1" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="20,16">
            <TextBlock Text="Profiles" FontSize="16" FontWeight="Bold" />
            <Button DockPanel.Dock="Right" Style="{StaticResource LinkButton}" Click="Done_Click">
                <TextBlock Text="Done" Foreground="{StaticResource AccentPurple}" FontWeight="SemiBold" FontSize="13" />
            </Button>
        </DockPanel>
        <Rectangle Grid.Row="1" Fill="{StaticResource GlassStroke}" />

        <ScrollViewer Grid.Row="2" Padding="16">
            <ItemsControl x:Name="ProfileList" />
        </ScrollViewer>

        <Rectangle Grid.Row="3" Fill="{StaticResource GlassStroke}" />
        <Button Grid.Row="4" Style="{StaticResource LinkButton}" Click="Add_Click" Margin="20,16">
            <DockPanel>
                <TextBlock Text="＋  Add New Profile"
                           Foreground="{StaticResource AccentPurple}" FontWeight="SemiBold" FontSize="13" />
            </DockPanel>
        </Button>
    </Grid>
</Window>
