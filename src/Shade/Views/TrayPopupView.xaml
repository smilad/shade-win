<UserControl x:Class="Shade.Views.TrayPopupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="280" Background="{StaticResource WindowBackground}">
    <Border Background="{StaticResource WindowBackground}"
            BorderBrush="{StaticResource GlassStroke}" BorderThickness="1" CornerRadius="10">
        <StackPanel Margin="0">

            <!-- Header -->
            <DockPanel Margin="14,12">
                <Border Width="34" Height="34" CornerRadius="8" Background="{StaticResource AccentPurple}"
                        VerticalAlignment="Center" Margin="0,0,12,0">
                    <TextBlock Text="S" Foreground="#FF111122" FontSize="18" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>

                <Button x:Name="PowerBtn" DockPanel.Dock="Right" Click="PowerBtn_Click"
                        Background="{StaticResource StartButtonBrush}" Cursor="Hand"
                        Padding="10,6" Height="28">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border CornerRadius="8" Background="{TemplateBinding Background}">
                                <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}" />
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="PowerIcon" Text="▶" Foreground="White" FontWeight="Bold"
                                   FontSize="9" Margin="0,0,5,0" VerticalAlignment="Center" />
                        <TextBlock x:Name="PowerLabel" Text="START" Foreground="White" FontWeight="Bold"
                                   FontSize="10" />
                    </StackPanel>
                </Button>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Shade" FontSize="13" FontWeight="Bold" />
                    <TextBlock x:Name="HeaderSubtitle" Text="Disconnected"
                               FontSize="10" Foreground="{StaticResource Secondary}" />
                </StackPanel>
            </DockPanel>

            <Rectangle Height="1" Fill="{StaticResource GlassStroke}" Opacity="0.5" />

            <!-- Speed bars (visible only while running) -->
            <StackPanel x:Name="MeterPanel" Margin="14,11" Visibility="Collapsed">
                <DockPanel Margin="0,0,0,5">
                    <TextBlock Text="↓" Width="10" Foreground="{StaticResource AccentCyan}"
                               FontWeight="Bold" />
                    <TextBlock x:Name="SpeedDownText" Text="0 KB/s" Style="{StaticResource MonoText}"
                               DockPanel.Dock="Right" Width="60" TextAlignment="Right"
                               Foreground="{StaticResource AccentCyan}" />
                    <Border Height="6" Margin="6,0" CornerRadius="3" Background="#10FFFFFF"
                            ClipToBounds="True">
                        <Rectangle x:Name="SpeedDownBar" Fill="{StaticResource DownBarBrush}"
                                   HorizontalAlignment="Left" Width="0" />
                    </Border>
                </DockPanel>
                <DockPanel>
                    <TextBlock Text="↑" Width="10" Foreground="{StaticResource AccentPurple}"
                               FontWeight="Bold" />
                    <TextBlock x:Name="SpeedUpText" Text="0 KB/s" Style="{StaticResource MonoText}"
                               DockPanel.Dock="Right" Width="60" TextAlignment="Right"
                               Foreground="{StaticResource AccentPurple}" />
                    <Border Height="6" Margin="6,0" CornerRadius="3" Background="#10FFFFFF"
                            ClipToBounds="True">
                        <Rectangle x:Name="SpeedUpBar" Fill="{StaticResource UpBarBrush}"
                                   HorizontalAlignment="Left" Width="0" />
                    </Border>
                </DockPanel>
            </StackPanel>

            <Rectangle Height="1" Fill="{StaticResource GlassStroke}" Opacity="0.5" />

            <!-- Profile + uptime + system proxy -->
            <StackPanel Margin="14,12">
                <DockPanel Margin="0,0,0,8">
                    <TextBlock Text="👤" Foreground="{StaticResource AccentPurple}"
                               FontSize="11" Margin="0,0,8,0" />
                    <TextBlock x:Name="UptimeText" Text="" DockPanel.Dock="Right"
                               Style="{StaticResource MonoText}" FontSize="10"
                               Foreground="{StaticResource Secondary}" />
                    <TextBlock x:Name="ProfileNameText" Text="No Profile" FontSize="11" FontWeight="SemiBold" />
                </DockPanel>

                <DockPanel Margin="0,0,0,4">
                    <TextBlock Text="🛡" Foreground="{StaticResource AccentOrange}"
                               FontSize="11" Margin="0,0,8,0" />
                    <CheckBox DockPanel.Dock="Right" x:Name="SystemProxyToggle"
                              Style="{StaticResource ToggleSwitch}" Click="SystemProxyToggle_Click" />
                    <TextBlock Text="System Proxy" FontSize="11" />
                </DockPanel>

                <DockPanel x:Name="ListenerRow" Visibility="Collapsed">
                    <TextBlock Text="⚡" Foreground="{StaticResource AccentCyan}"
                               FontSize="11" Margin="0,0,8,0" />
                    <TextBlock x:Name="ListenerText" Text="SOCKS5 127.0.0.1:8080"
                               Style="{StaticResource MonoText}" FontSize="10" />
                </DockPanel>
            </StackPanel>

            <Rectangle Height="1" Fill="{StaticResource GlassStroke}" Opacity="0.5" />

            <!-- Footer buttons -->
            <Grid Margin="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="1" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Style="{StaticResource LinkButton}" Click="Dashboard_Click"
                        Padding="10,8">
                    <TextBlock Text="🟦 Dashboard" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource Primary}" HorizontalAlignment="Center" />
                </Button>
                <Rectangle Grid.Column="1" Fill="{StaticResource GlassStroke}" Width="1" />
                <Button Grid.Column="2" Style="{StaticResource LinkButton}" Click="Quit_Click"
                        Padding="10,8">
                    <TextBlock Text="🔌 Quit" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource AccentRed}" HorizontalAlignment="Center" />
                </Button>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
