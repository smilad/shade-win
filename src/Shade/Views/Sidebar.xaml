<UserControl x:Class="Shade.Views.Sidebar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#08FFFFFF">
    <Border BorderBrush="{StaticResource GlassStroke}" BorderThickness="0,0,1,0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Brand row -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="16,28,16,14">
                <Border Width="30" Height="30" CornerRadius="8" Background="{StaticResource AccentPurple}">
                    <TextBlock Text="S" Foreground="#FF111122"
                               FontSize="16" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock Text="Shade" FontSize="15" FontWeight="SemiBold"
                           Margin="10,0,0,0" VerticalAlignment="Center" />
            </StackPanel>

            <!-- Tabs -->
            <StackPanel Grid.Row="1" Margin="10,0,10,0">
                <ToggleButton x:Name="TabDashboard" Style="{StaticResource SidebarItem}" Margin="0,0,0,2"
                              Click="OnTabClick" Tag="Dashboard">
                    <DockPanel>
                        <TextBlock Text="⚡" Width="18" FontSize="13" />
                        <TextBlock Text="Dashboard" FontSize="13" />
                    </DockPanel>
                </ToggleButton>

                <ToggleButton x:Name="TabSetup" Style="{StaticResource SidebarItem}" Margin="0,0,0,2"
                              Click="OnTabClick" Tag="Setup">
                    <DockPanel>
                        <TextBlock Text="✨" Width="18" FontSize="13" />
                        <TextBlock Text="Setup Guide" FontSize="13" />
                    </DockPanel>
                </ToggleButton>

                <ToggleButton x:Name="TabSettings" Style="{StaticResource SidebarItem}" Margin="0,0,0,2"
                              Click="OnTabClick" Tag="Settings">
                    <DockPanel>
                        <TextBlock Text="⚙" Width="18" FontSize="13" />
                        <TextBlock Text="Settings" FontSize="13" />
                    </DockPanel>
                </ToggleButton>

                <ToggleButton x:Name="TabLogs" Style="{StaticResource SidebarItem}" Margin="0,0,0,2"
                              Click="OnTabClick" Tag="Logs">
                    <DockPanel>
                        <TextBlock Text="📝" Width="18" FontSize="13" />
                        <TextBlock Text="Logs" FontSize="13" />
                    </DockPanel>
                </ToggleButton>

                <ToggleButton x:Name="TabAbout" Style="{StaticResource SidebarItem}" Margin="0,0,0,2"
                              Click="OnTabClick" Tag="About">
                    <DockPanel>
                        <TextBlock Text="ⓘ" Width="18" FontSize="13" />
                        <TextBlock Text="About" FontSize="13" />
                    </DockPanel>
                </ToggleButton>
            </StackPanel>

            <!-- Status chip -->
            <Border Grid.Row="2" Margin="14,0,14,16" Padding="10,8" CornerRadius="8"
                    Background="{StaticResource GlassFill}">
                <DockPanel>
                    <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="#FF6B7280"
                             VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock x:Name="StatusLabel" Text="Ready to connect"
                               FontSize="11" Foreground="{StaticResource Secondary}"
                               TextTrimming="CharacterEllipsis" />
                </DockPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
